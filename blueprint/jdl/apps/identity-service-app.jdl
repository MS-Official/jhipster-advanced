application {
  config {
    baseName identityService
    applicationType microservice
    packageName com.yourorg.platform.identity
    authenticationType oauth2
    prodDatabaseType postgresql
    devDatabaseType postgresql
    buildTool maven
    serviceDiscoveryType consul
    nativeLanguage en
    languages [en]
  }
  entities Tenant, UserProfile, OtpPolicy, OtpRequest, OtpAttempt
}
